# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: for dev test account creation (Supabase Dashboard → Settings → API → service_role)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI (use one or both)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Voice (optional)
# OPENAI_WHISPER_API_KEY=sk-...
# ELEVENLABS_API_KEY=...

# Stripe Billing
# Get these from https://dashboard.stripe.com
# STRIPE_SECRET_KEY=sk_live_...         (or sk_test_... for testing)
# STRIPE_WEBHOOK_SECRET=whsec_...       (from Stripe Dashboard → Webhooks)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...  (or pk_test_...)
# STRIPE_PRICE_ID_MONTHLY=price_...     (your $15/month price ID)
# STRIPE_PRICE_ID_YEARLY=price_...      (your $99/year price ID)
